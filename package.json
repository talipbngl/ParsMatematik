{
  "name": "parsmatematik",
  "version": "0.1.0",
  "private": true,
  "description": "Parsmatematik - Matematik özel dersleri için canlı ders, ödev, sınav ve öğrenci takip platformu.",
  "author": "Parsmatematik",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run type-check && npm run lint",
    "clean": "rimraf .next node_modules package-lock.json",
    "db:types": "supabase gen types typescript --local > src/shared/types/database.types.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "latest",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "rimraf": "latest",
    "supabase": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}